# Copia este archivo a `.env` y pon UNA de las dos formas de autenticación.
# El `.env` tiene tu token: NO lo subas al repo (ya está en .gitignore).

# --- Opción A: tu suscripción Claude (Pro/Max/Team) --------------------------
# Genera el token UNA vez en tu máquina (donde ya iniciaste sesión en Claude Code):
#     claude setup-token
# Pega el resultado aquí. Usa tu plan (no la API de pago). Dura ~1 año.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Opción B: clave de la API de Anthropic (pago por uso) -------------------
# Alternativa a la opción A; se factura aparte a tu organización del Console.
# Si defines ambas, ANTHROPIC_API_KEY tiene prioridad.
# ANTHROPIC_API_KEY=

# --- Opcionales (ya vienen en la imagen; descomenta para cambiar) ------------
# CLAUDE_FLAGS=--dangerously-skip-permissions   # el contenedor es el sandbox
# IA_CWD=/workspace                             # dónde opera Claude
# CLAUDE_TIMEOUT=0                              # segundos por respuesta, 0 = sin límite
# CLAUDE_BIN=claude                             # binario de Claude Code
